{
  "private": true,
  "$schema": "https://json.schemastore.org/package.json",
  "version": "2.1.49",
  "name": "@pothos-examples/complex-app",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "generate": "prisma generate && pnpm run schema",
    "schema": "node scripts/build-schema.ts",
    "seed": "prisma migrate reset -f",
    "start": "node src/server.ts",
    "type": "tsc --noEmit",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "prisma": {
    "seed": "node prisma/seed.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@pothos/core": "workspace:*",
    "@pothos/plugin-dataloader": "workspace:*",
    "@pothos/plugin-prisma": "workspace:*",
    "@pothos/plugin-prisma-utils": "workspace:*",
    "@pothos/plugin-relay": "workspace:*",
    "@pothos/plugin-scope-auth": "workspace:*",
    "@pothos/plugin-simple-objects": "workspace:*",
    "@pothos/plugin-validation": "workspace:*",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "graphql": "^16.13.2",
    "graphql-scalars": "^1.25.0",
    "graphql-yoga": "5.21.0",
    "prisma": "^7.7.0",
    "react": "^19.2.5",
    "urql": "^5.0.1",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "6.3.0",
    "@graphql-codegen/client-preset": "5.3.0",
    "@graphql-codegen/introspection": "5.0.2",
    "@graphql-codegen/schema-ast": "^5.0.2",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
