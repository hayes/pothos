{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "target": "es2019",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "types": ["node"]
  },
  "include": ["prisma/*.ts", "src/**/*", "scripts/**/*"]
}
