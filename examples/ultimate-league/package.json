{
  "private": true,
  "$schema": "https://json.schemastore.org/package.json",
  "version": "0.1.0",
  "name": "@pothos-examples/ultimate-league",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "start": "node src/server.ts",
    "type": "tsgo --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node db/seed.ts",
    "db:reset": "rm -f db/dev.db && pnpm run db:migrate && pnpm run db:seed"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@pothos/core": "workspace:*",
    "@pothos/plugin-drizzle": "workspace:*",
    "@pothos/plugin-scope-auth": "workspace:*",
    "@pothos/plugin-validation": "workspace:*",
    "drizzle-orm": "1.0.0-rc.2",
    "graphql": "^16.13.2",
    "graphql-yoga": "5.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "drizzle-kit": "1.0.0-rc.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
