    "graphql": "^16.13.2",
    "graphql-helix": "^1.13.0",
    "graphql-tag": "^2.12.6",
    "graphql-yoga": "5.21.0",
    "next": "16.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.3.0",
