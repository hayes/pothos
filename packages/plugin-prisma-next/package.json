{
  "name": "@pothos/plugin-prisma-next",
  "version": "0.1.0",
  "description": "A Pothos plugin for the new prisma-next client",
  "main": "./lib/index.js",
  "types": "./dts/index.d.ts",
  "module": "./esm/index.js",
  "exports": {
    "import": {
      "default": "./esm/index.js"
    },
    "require": {
      "types": "./dts/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "type": "tsgo --project tsconfig.type.json",
    "build": "pnpm build:clean && pnpm build:cjs && pnpm build:dts && pnpm build:esm",
    "build:clean": "git clean -dfX esm lib",
    "build:cjs": "swc src -d lib --config-file ../../.swcrc -C module.type=commonjs --strip-leading-paths",
    "build:esm": "cp -r dts/* esm/ && swc src -d esm --config-file ../../.swcrc -C module.type=es6 --strip-leading-paths && pnpm esm:extensions",
    "build:dts": "tsgo",
    "esm:extensions": "TS_NODE_PROJECT=../../tsconfig.json node -r @swc-node/register ../../scripts/esm-transformer.ts",
    "test": "pnpm vitest --run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hayes/pothos.git",
    "directory": "packages/plugin-prisma-next"
  },
  "author": "Michael Hayes",
  "license": "ISC",
  "keywords": [
    "pothos",
    "graphql",
    "schema",
    "typescript",
    "prisma",
    "prisma-next",
    "plugin"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@pothos/core": "*",
    "@pothos/plugin-relay": "*",
    "@pothos/plugin-with-input": "*",
    "@prisma-next/contract": "^0.14.0",
    "@prisma-next/sql-contract": "^0.14.0",
    "@prisma-next/sql-orm-client": "^0.14.0",
    "graphql": "^16.10.0 || ^17.0.0"
  },
  "peerDependenciesMeta": {
    "@pothos/plugin-relay": {
      "optional": true
    },
    "@pothos/plugin-with-input": {
      "optional": true
    }
  },
  "devDependencies": {
    "@pothos/core": "workspace:*",
    "@pothos/plugin-errors": "workspace:*",
    "@pothos/plugin-relay": "workspace:*",
    "@pothos/plugin-with-input": "workspace:*",
    "@pothos/test-utils": "workspace:*",
    "@prisma-next/adapter-sqlite": "^0.14.0",
    "@prisma-next/contract": "^0.14.0",
    "@prisma-next/driver-sqlite": "^0.14.0",
    "@prisma-next/framework-components": "^0.14.0",
    "@prisma-next/sql-builder": "^0.14.0",
    "@prisma-next/sql-contract": "^0.14.0",
    "@prisma-next/sql-orm-client": "^0.14.0",
    "@prisma-next/sql-relational-core": "^0.14.0",
    "@prisma-next/sql-runtime": "^0.14.0",
    "@prisma-next/sqlite": "^0.14.0",
    "@prisma-next/target-sqlite": "^0.14.0"
  }
}
