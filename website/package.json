{
  "name": "@pothos/website",
  "private": true,
  "scripts": {
    "dev": "pnpm run bundle-types && pnpm run build-examples && next dev",
    "build": "pnpm run bundle-types && pnpm run build-examples && pnpm run check-playground-refs && pnpm run type",
    "next-build": "next build",
    "build-ci": "pnpm turbo run build && pnpm run bundle-types && pnpm run build-examples && pnpm run check-playground-refs && pnpm run type && next build",
    "start": "next start",
    "bundle-types": "tsx scripts/bundle-types.ts",
    "build-examples": "tsx scripts/build-playground-examples.ts",
    "check-playground-refs": "tsx scripts/check-playground-references.ts",
    "type": "tsc --noEmit",
    "test": "pnpm run build-examples && pnpm run test:examples && pnpm run test:docs",
    "test:examples": "tsx scripts/test-playground-examples.ts",
    "test:docs": "vitest run tests/playground-docs-validation.test.ts",
    "postinstall": "fumadocs-mdx"
  },
  "engines": {
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@pothos/core": "workspace:^",
    "@pothos/plugin-add-graphql": "workspace:^",
    "@pothos/plugin-complexity": "workspace:^",
    "@pothos/plugin-dataloader": "workspace:^",
    "@pothos/plugin-directives": "workspace:^",
    "@pothos/plugin-errors": "workspace:^",
    "@pothos/plugin-mocks": "workspace:^",
    "@pothos/plugin-relay": "workspace:^",
    "@pothos/plugin-scope-auth": "workspace:^",
    "@pothos/plugin-simple-objects": "workspace:^",
    "@pothos/plugin-sub-graph": "workspace:^",
    "@pothos/plugin-validation": "workspace:^",
    "@pothos/plugin-with-input": "workspace:^",
    "@tailwindcss/postcss": "^4.2.2",
    "dataloader": "^2.2.3",
    "@typescript/ata": "^0.9.8",
    "class-variance-authority": "^0.7.1",
    "esbuild-wasm": "^0.27.1",
    "fumadocs-core": "16.7.15",
    "fumadocs-docgen": "^3.0.10",
    "fumadocs-mdx": "14.2.14",
    "fumadocs-ui": "16.7.15",
    "graphql": "^16.13.2",
    "graphql-language-service": "^5.5.0",
    "lucide-react": "^1.8.0",
    "lz-string": "^1.5.0",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/lz-string": "^1.5.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "glob": "^13.0.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "unist-util-visit": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
